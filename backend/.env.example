# MongoDB Atlas connection string (SRV format)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cyberpunk?retryWrites=true&w=majority

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Exact origin of the frontend (used for CORS + cookie). No trailing slash.
CLIENT_URL=http://localhost:5173

# Port the server listens on (Render injects its own PORT in production)
PORT=5000

# development | production
NODE_ENV=development
